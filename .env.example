# ─── Required ────────────────────────────────────────────────────
# Groq API key for the AI Advisor tab (LangGraph + Llama 3.3-70b).
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional ────────────────────────────────────────────────────
# Override the default Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Override LLM sampling temperature for advisory reports (default: 0.2)
# Lower = more deterministic, Higher = more creative
# GROQ_TEMPERATURE=0.2
